<Window x:Class="FolMinder2.Presentation.ConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FolMinder2.Presentation"
        xmlns:vms="clr-namespace:FolMinder2.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vms:ConfigViewModel}"
        Title="FolMinder2の設定"
        SizeToContent="WidthAndHeight"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Icon="/Assets/folminder.ico"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="10,5,10,5"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="10,5,10,5"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5,10,5"/>
            <Setter Property="Margin" Value="5,5,5,5"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5,5,5,5"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Margin" Value="10,5,10,5"/>
        </Style>
    </Window.Resources>
    <Border Margin="10,5,10,5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <CheckBox Grid.Row="0"
                      Content="選択したフォルダーをピン留めする"
                      IsChecked="{Binding PinSelectedFolder}"/>
            <CheckBox Grid.Row="1"
                      Content="英数字キーで選択に加えて開くまでする"
                      IsChecked="{Binding QuickSelect}"/>
            <GroupBox Grid.Row="2"
                      Header="ホットキー">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="修飾キー"/>
                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Orientation="Vertical">
                        <CheckBox x:Name="checkAlt"
                                  Content="Alt"
                                  IsChecked="{Binding WithAlt}"/>
                        <CheckBox Content="Control"
                                  IsChecked="{Binding WithControl}"/>
                        <CheckBox Content="Shift"
                                  IsChecked="{Binding WithShift}"/>
                        <CheckBox Content="Win"
                                  IsChecked="{Binding WithWin}"/>
                    </StackPanel>
                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="キー"/>
                    <ListBox Grid.Row="1"
                             Grid.Column="1"
                             x:Name="keyListBox"
                             ItemsSource="{Binding Items}"
                             DisplayMemberPath="Name"
                             SelectedItem="{Binding SelectedItem}"
                             Width="120"
                             Height="140"/>
                </Grid>

            </GroupBox>
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Grid.Column="1"
                        Content="OK"
                        Command="{Binding AcceptCommand}"
                        IsDefault="True"
                        Padding="20,5,20,5"/>
                <Button Grid.Column="2"
                        Content="キャンセル"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

<Window x:Class="FolMinder2.Presentation.ConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FolMinder2.Presentation"
        xmlns:vms="clr-namespace:FolMinder2.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vms:ConfigViewModel}"
        Title="FolMinder2の設定"
        SizeToContent="Width"
        Height="450"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="/Assets/folminder.ico"
        ResizeMode="NoResize">
    <Grid Margin="10,10,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="修飾キー"
                   Margin="10,5,10,5"/>
        <StackPanel Grid.Row="1" Grid.Column="0">
            <CheckBox x:Name="checkAlt"
                      Content="Alt"
                      IsChecked="{Binding WithAlt}"
                      HorizontalAlignment="Left"
                      Margin="10,5,10,5"/>
            <CheckBox Content="Control"
                      IsChecked="{Binding WithControl}"
                      HorizontalAlignment="Left"
                      Margin="10,5,10,5"/>
            <CheckBox Content="Shift"
                      IsChecked="{Binding WithShift}"
                      HorizontalAlignment="Left"
                      Margin="10,5,10,5"/>
            <CheckBox Content="Win"
                      IsChecked="{Binding WithWin}"
                      HorizontalAlignment="Left"
                      Margin="10,5,10,5"/>
        </StackPanel>
        <TextBlock Grid.Row="0"
                   Grid.Column="1"
                   Text="キー"
                   Margin="10,5,10,5"/>
        <ListBox Grid.Row="1"
                 Grid.Column="1"
                 x:Name="keyListBox"
                 ItemsSource="{Binding Items}"
                 DisplayMemberPath="Name"
                 SelectedItem="{Binding SelectedItem}"
                 Margin="10,5,10,5"
                 Width="120"/>
        <StackPanel Grid.Row="1" Grid.Column="2">
            <Button Content="OK"
                    Command="{Binding AcceptCommand}"
                    IsDefault="True"
                    Margin="10,5,10,5"
                    Padding="10,5,10,5"/>
            <Button Content="キャンセル"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Margin="10,5,10,5"
                    Padding="10,5,10,5"/>
        </StackPanel>
    </Grid>
</Window>

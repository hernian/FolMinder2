<Window x:Class="FolMinder2.Presentation.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FolMinder2.Presentation"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        WindowStyle="None"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Border">
            <Setter Property="Padding" Value="2,2,2,2"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="10,2,10,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="10,2,10,2"/>
            <Setter Property="Padding" Value="10,2,10,2"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <!-- Information -->
        <sys:TimeSpan x:Key="infoDuration">0:0:3</sys:TimeSpan>
        <SolidColorBrush x:Key="infoBackgroundBrush"  Color="#CC1A73E8"/>
        <SolidColorBrush x:Key="infoForegroundBrush"  Color="#FFFFFFFF"/>
        <!-- Error -->
        <sys:TimeSpan x:Key="errorDuration">0:0:6</sys:TimeSpan>
        <SolidColorBrush x:Key="errorBackgroundBrush" Color="#CCB00020"/>
        <SolidColorBrush x:Key="errorForegroundBrush" Color="#FFFFFFFF"/>
    </Window.Resources>
    <Border x:Name="toastBorder">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       x:Name="messageText">テストテストテストテスト</TextBlock>
            <Button Grid.Column="1"
                    x:Name="closeButton"
                    Content="✕"/>
        </Grid>
    </Border>
</Window>
